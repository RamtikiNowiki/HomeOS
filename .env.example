# Copy to .env and fill in real values before `docker compose up`.

# Flask
SECRET_KEY=generate-a-long-random-string-here

# PostgreSQL (the db container is created with these)
POSTGRES_USER=homeos
POSTGRES_PASSWORD=pick-a-strong-db-password
POSTGRES_DB=homeos

# Profiles — created automatically on first boot
SEED_USER1_USERNAME=ram
SEED_USER1_NAME=Ram
SEED_USER1_PASSWORD=pick-a-passcode

SEED_USER2_USERNAME=tiki
SEED_USER2_NAME=Tiki
SEED_USER2_PASSWORD=pick-another-passcode

# Set to 1 to seed demo exercises/sessions/weights on first boot, 0 to skip
SEED_DEMO_DATA=1

# Future integrations — leave blank for mock mode
HOME_ASSISTANT_URL=
HOME_ASSISTANT_TOKEN=
CREALITY_K2_HOST=
