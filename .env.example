# Copy to .env and fill in real values before `docker compose up`.
# Local dev without Docker: copy to .env and run `python wsgi.py` — SQLite is used
# automatically when DATABASE_URL is unset.

# ── Flask ─────────────────────────────────────────────────────────────────────
SECRET_KEY=generate-a-long-random-string-here
# Set to 1 when serving over HTTPS (production behind TLS terminator)
COOKIE_SECURE=0

# PWA install URL — your Tailscale Serve HTTPS link (required for phone install)
# Example: https://raspberrypi.your-tailnet.ts.net
PWA_CANONICAL_URL=

# ── PostgreSQL (used by Docker Compose `db` service) ──────────────────────────
# Leave DATABASE_URL unset for local SQLite dev (instance/dev.db).
POSTGRES_USER=homeos
POSTGRES_PASSWORD=pick-a-strong-db-password
POSTGRES_DB=homeos

# ── User profiles — created automatically on first boot ───────────────────────
SEED_USER1_USERNAME=ram
SEED_USER1_NAME=Ram
SEED_USER1_PASSWORD=pick-a-passcode

SEED_USER2_USERNAME=aylin
SEED_USER2_NAME=Aylin
SEED_USER2_PASSWORD=pick-another-passcode

# 1 = seed demo exercises/sessions/weights on first boot, 0 = clean start
SEED_DEMO_DATA=0

# ── Home Assistant (leave blank for mock mode) ────────────────────────────────
# URL is your HA instance — no trailing slash. Token from Profile → Security.
HOME_ASSISTANT_URL=
HOME_ASSISTANT_TOKEN=
# Comma-separated light entity IDs (find in HA → Settings → Devices)
HOME_ASSISTANT_LIGHTS=
# Temperature/humidity sensor entity ID
HOME_ASSISTANT_SENSOR=

# ── Creality K2 Plus / Moonraker (leave blank for mock mode) ──────────────────
# Printer LAN IP only — Moonraker default port is 7125
CREALITY_K2_HOST=
CREALITY_K2_PORT=7125
CREALITY_K2_API_KEY=
# Optional camera — usually auto-detected after Creality Helper Script "Camera Support"
CREALITY_K2_CAMERA_SNAPSHOT_URL=
CREALITY_K2_FLUIDD_URL=
